generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String  @unique
  description String?

  users           User[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String  @unique
  description String?

  rolePermissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permissions")
}

model RolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id String @id @default(uuid())

  schoolId String?

  roleId String

  username String

  email String?

  mobile String?

  passwordHash String

  status UserStatus @default(ACTIVE)

  isFirstLogin Boolean @default(true)

  lastLoginAt DateTime?

  role Role @relation(fields: [roleId], references: [id])

  sessions Session[]

  refreshTokens RefreshToken[]

  auditLogs AuditLog[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([schoolId, username])
  @@map("users")
}

model Session {
  id String @id @default(uuid())

  userId String

  ipAddress String?

  userAgent String?

  status SessionStatus @default(ACTIVE)

  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("sessions")
}

model RefreshToken {
  id String @id @default(uuid())

  userId String

  token String @unique

  expiresAt DateTime

  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model AuditLog {
  id String @id @default(uuid())

  userId String?

  action String

  module String

  description String?

  ipAddress String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
